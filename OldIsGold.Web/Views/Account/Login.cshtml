@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="container" style="margin-top: 80px; margin-bottom: 80px; max-width: 500px;">
    <div class="card card-light" style="padding: 40px;">
        <div style="text-align: center; margin-bottom: 30px;">
            <h2 style="color: var(--gold); margin-bottom: 10px;">
                ✨ Welcome Back
            </h2>
            <p style="color: var(--text-secondary);">
                Sign in to your Old is Gold account
            </p>
        </div>

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 20px; padding: 12px; background: rgba(255, 63, 52, 0.1); border-left: 3px solid #FF3F34; border-radius: 4px;"></div>
            
            <div style="margin-bottom: 20px;">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="your@email.com" autofocus />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div style="margin-bottom: 20px;">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div style="margin-bottom: 25px;">
                <div style="display: flex; align-items: center;">
                    <input asp-for="RememberMe" type="checkbox" style="margin-right: 8px; width: 18px; height: 18px; cursor: pointer;" />
                    <label asp-for="RememberMe" style="margin: 0; cursor: pointer; color: var(--text-secondary);">
                        Remember me on this device
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 15px; font-size: 1.1rem;">
                Sign In
            </button>
        </form>

        <div style="text-align: center; margin-top: 25px; padding-top: 25px; border-top: 1px solid var(--brown-card);">
            <p style="color: var(--text-secondary); margin-bottom: 10px;">
                Don't have an account? 
                <a href="@Url.Action("Register", "Account")" style="color: var(--neon-green); text-decoration: none; font-weight: 600;">
                    Create Account
                </a>
            </p>
        </div>
    </div>

    <!-- Quick Admin Login (for development) -->
    @if (Context.Request.Host.Host == "localhost")
    {
        <div style="margin-top: 20px; padding: 15px; background: rgba(57, 255, 20, 0.1); border-radius: 8px; border: 1px solid var(--neon-green);">
            <p style="margin: 0; font-size: 0.9rem; color: var(--text-secondary); text-align: center;">
                <strong style="color: var(--neon-green);">Dev Mode:</strong> 
                Admin: admin@oldsgold.com / Admin@123 | 
                Buyer: buyer@test.com / Test@123
            </p>
        </div>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
