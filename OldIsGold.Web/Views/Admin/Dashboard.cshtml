@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <h1 style="color: var(--brown-dark); margin-bottom: 30px;">Admin Dashboard</h1>

    <!-- Stats -->
    <div class="grid grid-4" style="margin-bottom: 40px;">
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 10px;">👥</div>
            <h3 style="color: var(--gold);">@ViewBag.TotalUsers</h3>
            <p>Total Users</p>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 10px;">📦</div>
            <h3 style="color: var(--gold);">@ViewBag.TotalItems</h3>
            <p>Total Items</p>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 10px;">⏳</div>
            <h3 style="color: var(--neon-orange);">@ViewBag.PendingItems</h3>
            <p>Pending Items</p>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 10px;">⚠️</div>
            <h3 style="color: var(--neon-pink);">@ViewBag.PendingReports</h3>
            <p>Pending Reports</p>
        </div>
    </div>

    <!-- Quick Actions -->
    <div style="display: flex; gap: 20px; margin-bottom: 40px;">
        <a href="/Admin/Items?status=Pending" class="btn btn-primary" style="flex: 1; text-align: center;">Review Pending Items</a>
        <a href="/Admin/Reports" class="btn btn-danger" style="flex: 1; text-align: center;">Manage Reports</a>
        <a href="/Admin/Users" class="btn btn-secondary" style="flex: 1; text-align: center;">Manage Users</a>
    </div>

    <div class="row" style="display: flex; gap: 30px; flex-wrap: wrap;">
        <!-- Recent Users -->
        <div style="flex: 1; min-width: 300px;">
            <div class="card card-light">
                <h3 style="color: var(--brown-dark); margin-bottom: 20px;">Newest Members</h3>
                @if (ViewBag.RecentUsers != null)
                {
                    foreach (var user in ViewBag.RecentUsers)
                    {
                        <div style="display: flex; align-items: center; gap: 15px; padding: 10px 0; border-bottom: 1px solid #ddd;">
                            <div style="width: 40px; height: 40px; background: var(--brown-card); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--gold); font-weight: bold;">
                                @(user.FullName?.Substring(0, 1) ?? "U")
                            </div>
                            <div>
                                <div style="font-weight: bold;">@user.FullName</div>
                                <div style="font-size: 0.8rem; color: #666;">@user.UserType • @user.JoinDate.ToString("MMM dd")</div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- System Links -->
        <div style="flex: 1; min-width: 300px;">
            <div class="card card-light">
                <h3 style="color: var(--brown-dark); margin-bottom: 20px;">System</h3>
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <a href="/Admin/Categories" class="btn btn-secondary" style="text-align: left;">📂 Manage Categories</a>
                    <a href="/Admin/Logs" class="btn btn-secondary" style="text-align: left;">📜 View Audit Logs</a>
                </div>
            </div>
        </div>
    </div>
</div>
