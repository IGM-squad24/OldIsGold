@model IEnumerable<OldIsGold.DAL.Models.AdminLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <h1 style="color: var(--brown-dark); margin-bottom: 30px;">Audit Logs</h1>

    <div class="card" style="padding: 0; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead style="background: var(--brown-card); color: var(--text-light);">
                <tr>
                    <th style="padding: 15px; text-align: left;">Date</th>
                    <th style="padding: 15px; text-align: left;">Admin</th>
                    <th style="padding: 15px; text-align: left;">Action</th>
                    <th style="padding: 15px; text-align: left;">Target</th>
                    <th style="padding: 15px; text-align: left;">Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 15px;">@log.Date.ToString("yyyy-MM-dd HH:mm")</td>
                        <td style="padding: 15px;">@log.Admin?.FullName</td>
                        <td style="padding: 15px;">
                            <span class="badge" style="background: #eee; color: #333;">@log.Action</span>
                        </td>
                        <td style="padding: 15px;">@log.TargetType #@log.TargetId</td>
                        <td style="padding: 15px;">@log.Description</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
