@model IEnumerable<OldIsGold.DAL.Models.ApplicationUser>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <h1 style="color: var(--brown-dark); margin-bottom: 30px;">Manage Users</h1>

    <div class="card" style="margin-bottom: 30px;">
        <form asp-action="Users" method="get" style="display: flex; gap: 10px;">
            <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name or email..." style="flex-grow: 1;">
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead style="background: var(--brown-card); color: var(--text-light);">
                <tr>
                    <th style="padding: 15px; text-align: left;">User</th>
                    <th style="padding: 15px; text-align: left;">Role</th>
                    <th style="padding: 15px; text-align: left;">Joined</th>
                    <th style="padding: 15px; text-align: center;">Status</th>
                    <th style="padding: 15px; text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 15px;">
                            <div style="font-weight: bold;">@user.FullName</div>
                            <div style="font-size: 0.8rem; color: #666;">@user.Email</div>
                        </td>
                        <td style="padding: 15px;">
                            <span class="badge" style="background: #eee; color: #333;">@user.UserType</span>
                        </td>
                        <td style="padding: 15px;">@user.JoinDate.ToString("MMM dd, yyyy")</td>
                        <td style="padding: 15px; text-align: center;">
                            @if (user.IsActive)
                            {
                                <span class="badge badge-approved">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-rejected">Banned</span>
                            }
                        </td>
                        <td style="padding: 15px; text-align: right;">
                            @if (user.IsActive)
                            {
                                <form asp-action="BanUser" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to ban this user?');">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-danger" style="padding: 5px 10px; font-size: 0.8rem;">Ban</button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="UnbanUser" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to unban this user?');">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-primary" style="padding: 5px 10px; font-size: 0.8rem;">Unban</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
