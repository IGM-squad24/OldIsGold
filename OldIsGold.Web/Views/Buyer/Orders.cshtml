@model IEnumerable<OldIsGold.DAL.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <h1 style="color: var(--brown-dark); margin-bottom: 30px;">📦 My Orders</h1>

    @if (!Model.Any())
    {
        <div class="card" style="text-align: center; padding: 50px;">
            <div style="font-size: 4rem; margin-bottom: 20px;">🛒</div>
            <h3>No orders yet</h3>
            <p>You haven't purchased any items yet.</p>
            <a href="/Item" class="btn btn-primary" style="margin-top: 20px;">Start Shopping</a>
        </div>
    }
    else
    {
        <div style="display: flex; flex-direction: column; gap: 20px;">
            @foreach (var order in Model)
            {
                <div class="card card-light" style="display: flex; gap: 20px; align-items: center; padding: 20px;">
                    <div style="width: 100px; height: 100px; flex-shrink: 0;">
                        @if (order.Item.Images != null && order.Item.Images.Any())
                        {
                            var mainImage = order.Item.Images.FirstOrDefault(i => i.IsMain) ?? order.Item.Images.First();
                            <img src="data:@mainImage.ContentType;base64,@Convert.ToBase64String(mainImage.ImageData)" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" alt="@order.Item.Title">
                        }
                        else
                        {
                            <div style="width: 100%; height: 100%; background: #ddd; border-radius: 8px; display: flex; align-items: center; justify-content: center;">No Image</div>
                        }
                    </div>
                    
                    <div style="flex-grow: 1;">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <h3 style="margin: 0; font-size: 1.2rem;">@order.Item.Title</h3>
                            <span class="badge @(order.Status == OldIsGold.DAL.Models.OrderStatus.Completed ? "badge-approved" : "badge-pending")">
                                @order.Status
                            </span>
                        </div>
                        <div style="color: #666; font-size: 0.9rem; margin-bottom: 5px;">
                            Order #@order.OrderId • @order.OrderDate.ToString("MMM dd, yyyy")
                        </div>
                        <div style="font-weight: bold; color: var(--brown-dark);">
                            Total: $@order.TotalAmount.ToString("N2")
                        </div>
                    </div>

                    <div>
                        <a href="/Order/Details/@order.OrderId" class="btn btn-secondary" style="padding: 8px 15px; font-size: 0.9rem;">View Details</a>
                    </div>
                </div>
            }
        </div>
    }
</div>
