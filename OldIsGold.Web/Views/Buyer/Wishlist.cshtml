@model IEnumerable<OldIsGold.DAL.Models.Wishlist>
@{
    ViewData["Title"] = "My Wishlist";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <h1 style="color: var(--brown-dark); margin-bottom: 30px;">❤️ My Wishlist</h1>

    @if (!Model.Any())
    {
        <div class="card" style="text-align: center; padding: 50px;">
            <div style="font-size: 4rem; margin-bottom: 20px;">💔</div>
            <h3>Your wishlist is empty</h3>
            <p>Browse our collection and save your favorite items here.</p>
            <a href="/Item" class="btn btn-primary" style="margin-top: 20px;">Browse Items</a>
        </div>
    }
    else
    {
        <div class="grid grid-4">
            @foreach (var item in Model)
            {
                <div class="item-card" onclick="location.href='/Item/Details/@item.ItemId'">
                    <div style="position: relative;">
                        @if (item.Item.Images != null && item.Item.Images.Any())
                        {
                            var mainImage = item.Item.Images.FirstOrDefault(i => i.IsMain) ?? item.Item.Images.First();
                            <img src="data:@mainImage.ContentType;base64,@Convert.ToBase64String(mainImage.ImageData)" alt="@item.Item.Title">
                        }
                        else
                        {
                            <div style="height: 250px; background: #ddd; display: flex; align-items: center; justify-content: center; color: #888;">
                                No Image
                            </div>
                        }
                        <form asp-controller="Item" asp-action="RemoveFromWishlist" asp-route-id="@item.ItemId" method="post" style="position: absolute; top: 10px; right: 10px; z-index: 10;">
                            <button type="submit" class="btn btn-danger" style="padding: 5px 10px; border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;" title="Remove from Wishlist" onclick="event.stopPropagation();">
                                ✕
                            </button>
                        </form>
                    </div>
                    <div class="item-card-body">
                        <h4 class="item-card-title" style="font-size: 1rem;">@item.Item.Title</h4>
                        <div class="item-card-price" style="font-size: 1.2rem;">$@item.Item.Price.ToString("N2")</div>
                        <div style="font-size: 0.8rem; color: #888; margin-top: 5px;">Added on @item.AddedDate.ToString("MMM dd, yyyy")</div>
                    </div>
                </div>
            }
        </div>
    }
</div>
