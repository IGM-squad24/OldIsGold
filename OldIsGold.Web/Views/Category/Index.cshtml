@model IEnumerable<OldIsGold.DAL.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <div style="text-align: center; margin-bottom: 50px;">
        <h1 class="hero-title" style="color: var(--brown-dark); font-size: 3rem;">Explore Categories</h1>
        <p class="hero-subtitle" style="color: var(--text-secondary); font-size: 1.2rem;">Discover unique treasures across our curated collections</p>
    </div>

    <div class="grid grid-3">
        @foreach (var category in Model)
        {
            <div class="category-card" onclick="location.href='/Item?categoryId=@category.CategoryId'">
                <div class="category-icon">@category.Icon</div>
                <h3 class="category-name">@category.Name</h3>
                <p style="color: #ddd; margin-bottom: 15px;">@category.Description</p>
                <div class="badge badge-approved" style="background: rgba(0,0,0,0.3);">
                    @(category.Items?.Count ?? 0) Items
                </div>
            </div>
        }
    </div>
</div>
