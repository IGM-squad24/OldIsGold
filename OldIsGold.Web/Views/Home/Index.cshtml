@{
    ViewData["Title"] = "Home";
    var categories = ViewBag.Categories as List<OldIsGold.DAL.Models.Category> ?? new List<OldIsGold.DAL.Models.Category>();
    var featuredItems = ViewBag.FeaturedItems as List<OldIsGold.DAL.Models.Item> ?? new List<OldIsGold.DAL.Models.Item>();
}

<!-- Hero Section -->
<div class="hero">
    <div class="container">
        <h1 class="hero-title">✨ Old is Gold</h1>
        <p class="hero-subtitle">A Modern Marketplace for Rare Antiques & Timeless Collectibles</p>
        <div style="margin-top: 30px; position: relative; z-index: 2;">
            <a href="/Item" class="btn btn-primary" style="margin-right: 15px;">Browse Items</a>
            
            @if (!User.Identity.IsAuthenticated)
            {
                <a href="/Account/Register" class="btn btn-secondary">Start Selling</a>
            }
            else if (User.IsInRole("Seller"))
            {
                <a href="/Seller/CreateItem" class="btn btn-secondary">List New Item</a>
            }
            else if (User.IsInRole("Admin"))
            {
                <a href="/Admin/Dashboard" class="btn btn-secondary">Dashboard</a>
            }
            else
            {
                <a href="/Buyer/Wishlist" class="btn btn-secondary">My Wishlist</a>
            }
        </div>
    </div>
</div>

<!-- Categories Section -->
<div class="container" style="margin-top: 60px;">
    <h2 style="text-align: center; margin-bottom: 40px; color: var(--brown-dark);">
        Explore Categories
    </h2>
    
    @if (categories.Any())
    {
        <div class="grid grid-3">
            @foreach (var category in categories)
            {
                <div class="category-card" onclick="window.location.href='/Category/Items/@category.CategoryId'">
                    <div class="category-icon">@category.Icon</div>
                    <div class="category-name">@category.Name</div>
                    <p style="margin-top: 10px; opacity: 0.9;">@category.Description</p>
                </div>
            }
        </div>
    }
    else
    {
        <p style="text-align: center;color: var(--text-secondary);">Categories will appear here once items are added.</p>
    }
</div>

<!-- Featured Items Section -->
<div class="container" style="margin-top: 80px;">
    <h2 style="text-align: center; margin-bottom: 40px; color: var(--brown-dark);">
        Featured Items
    </h2>
    
    @if (featuredItems.Any())
    {
        <div class="grid grid-4">
            @foreach (var item in featuredItems)
            {
                <div class="item-card" onclick="window.location.href='/Item/Details/@item.ItemId'">
                    @if (item.Images.Any())
                    {
                        <img src="/Image/GetImage/@item.Images.First().ImageId" alt="@item.Title" />
                    }
                    else
                    {
                        <div style="width: 100%; height: 250px; background: var(--brown-card); display: flex; align-items: center; justify-content: center; color: var(--text-light);">
                            No Image
                        </div>
                    }
                    <div class="item-card-body">
                        <div class="item-card-title">@item.Title</div>
                        <div style="margin: 10px 0;">
                            <span class="badge badge-approved">@item.Condition</span>
                            <span class="badge" style="background: var(--beige-bg); color: var(--text-main);">
                                @item.Category.Name
                            </span>
                        </div>
                        <div class="item-card-price">$@item.Price.ToString("N2")</div>
                        <div style="margin-top: 10px; color: var(--text-secondary); font-size: 0.9rem;">
                            by @item.Seller.FullName
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 60px 20px; background: var(--beige-light); border-radius: 12px;">
            <p style="font-size: 1.2rem; color: var(--text-secondary); margin-bottom: 20px;">
                No items available yet. Be the first to list an antique!
            </p>
            <a href="/Account/Register" class="btn btn-primary">Become a Seller</a>
        </div>
    }
</div>

<!-- Call to Action -->
<div class="container" style="margin-top: 80px; margin-bottom: 60px;">
    <div class="card" style="text-align: center; padding: 50px 30px;">
        <h2 style="color: var(--neon-green); margin-bottom: 20px;">Ready to Discover Rare Treasures?</h2>
        <p style="font-size: 1.1rem; margin-bottom: 30px; color: var(--beige-light);">
            Join our community of collectors, sellers, and antique enthusiasts
        </p>
        <div>
            <a href="/Account/Register" class="btn btn-primary" style="margin-right: 15px;">Join Now</a>
            <a href="/Item" class="btn btn-secondary">Browse Collection</a>
        </div>
    </div>
</div>
