@model IEnumerable<OldIsGold.DAL.Models.Item>
@{
    ViewData["Title"] = "Browse Items";
    var categories = ViewBag.Categories as List<OldIsGold.DAL.Models.Category>;
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <div class="row" style="display: flex; gap: 30px; flex-wrap: wrap;">
        
        <!-- Sidebar Filters -->
        <aside style="width: 280px; flex-shrink: 0;">
            <div class="card" style="position: sticky; top: 100px;">
                <h3 style="color: var(--gold); border-bottom: 1px solid var(--gold); padding-bottom: 10px; margin-bottom: 20px;">
                    🔍 Filters
                </h3>
                
                <form asp-action="Index" method="get">
                    <!-- Search -->
                    <div style="margin-bottom: 20px;">
                        <label class="form-label">Search</label>
                        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search items...">
                    </div>

                    <!-- Category -->
                    <div style="margin-bottom: 20px;">
                        <label class="form-label">Category</label>
                        <select name="categoryId" class="form-control">
                            <option value="">All Categories</option>
                            @if (categories != null)
                            {
                                foreach (var category in categories)
                                {
                                    <option value="@category.CategoryId" selected="@(ViewBag.CategoryId == category.CategoryId)">@category.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Price Range -->
                    <div style="margin-bottom: 20px;">
                        <label class="form-label">Price Range</label>
                        <div style="display: flex; gap: 10px;">
                            <input type="number" name="minPrice" value="@ViewBag.MinPrice" class="form-control" placeholder="Min">
                            <input type="number" name="maxPrice" value="@ViewBag.MaxPrice" class="form-control" placeholder="Max">
                        </div>
                    </div>

                    <!-- Condition -->
                    <div style="margin-bottom: 20px;">
                        <label class="form-label">Condition</label>
                        <select name="condition" class="form-control">
                            <option value="">Any Condition</option>
                            @foreach (var condition in Enum.GetValues(typeof(OldIsGold.DAL.Models.ItemCondition)))
                            {
                                <option value="@condition" selected="@(ViewBag.Condition?.ToString() == condition.ToString())">@condition</option>
                            }
                        </select>
                    </div>

                    <!-- Sort By -->
                    <div style="margin-bottom: 20px;">
                        <label class="form-label">Sort By</label>
                        <select name="sortBy" class="form-control">
                            <option value="newest" selected="@(ViewBag.SortBy == "newest")">Newest First</option>
                            <option value="oldest" selected="@(ViewBag.SortBy == "oldest")">Oldest First</option>
                            <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc")">Price: Low to High</option>
                            <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc")">Price: High to Low</option>
                            <option value="title" selected="@(ViewBag.SortBy == "title")">Name: A-Z</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary" style="width: 100%;">Apply Filters</button>
                    <a href="/Item" class="btn btn-secondary" style="width: 100%; margin-top: 10px; text-align: center;">Reset</a>
                </form>
            </div>
        </aside>

        <!-- Main Content -->
        <div style="flex-grow: 1; width: 100%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
                <h2 style="color: var(--brown-dark); margin: 0;">
                    Browse Collection <span style="font-size: 1rem; color: var(--text-secondary); font-weight: normal;">(@Model.Count() items found)</span>
                </h2>
            </div>

            @if (!Model.Any())
            {
                <div class="card" style="text-align: center; padding: 50px;">
                    <div style="font-size: 4rem; margin-bottom: 20px;">🏺</div>
                    <h3>No items found</h3>
                    <p>Try adjusting your filters or check back later for new treasures.</p>
                    <a href="/Item" class="btn btn-primary" style="margin-top: 20px;">View All Items</a>
                </div>
            }
            else
            {
                <div class="grid grid-3">
                    @foreach (var item in Model)
                    {
                        <div class="item-card" onclick="location.href='/Item/Details/@item.ItemId'">
                            <div style="position: relative;">
                                @if (item.Images != null && item.Images.Any())
                                {
                                    var mainImage = item.Images.FirstOrDefault(i => i.IsMain) ?? item.Images.First();
                                    <img src="data:@mainImage.ContentType;base64,@Convert.ToBase64String(mainImage.ImageData)" alt="@item.Title">
                                }
                                else
                                {
                                    <div style="height: 250px; background: #ddd; display: flex; align-items: center; justify-content: center; color: #888;">
                                        No Image
                                    </div>
                                }
                                <div style="position: absolute; top: 10px; right: 10px;">
                                    <span class="badge badge-approved">@item.Category?.Name</span>
                                </div>
                            </div>
                            <div class="item-card-body">
                                <h4 class="item-card-title">@item.Title</h4>
                                <div style="display: flex; justify-content: space-between; align-items: center;">
                                    <span class="item-card-price">$@item.Price.ToString("N2")</span>
                                    <span style="font-size: 0.9rem; color: #666;">@item.CreatedDate.ToString("MMM dd")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .row {
            flex-direction: column;
        }
        aside {
            width: 100% !important;
        }
        .card {
            position: static !important;
        }
    }
</style>
