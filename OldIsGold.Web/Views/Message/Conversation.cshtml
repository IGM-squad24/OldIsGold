@model IEnumerable<OldIsGold.DAL.Models.Message>
@{
    var contact = ViewBag.Contact as OldIsGold.DAL.Models.ApplicationUser;
    ViewData["Title"] = "Chat with " + contact?.FullName;
    var userId = (string)ViewBag.CurrentUserId; // Need to pass this from controller or use User.Identity
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <div style="margin-bottom: 20px;">
        <a href="/Message" style="color: var(--text-secondary); text-decoration: none;">&larr; Back to Inbox</a>
    </div>

    <div class="card" style="height: 70vh; display: flex; flex-direction: column; padding: 0; overflow: hidden;">
        <!-- Header -->
        <div style="padding: 15px; background: rgba(0,0,0,0.2); border-bottom: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; gap: 15px;">
            <div style="width: 40px; height: 40px; background: var(--gold); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; color: var(--brown-dark);">
                @(contact?.FullName?.Substring(0, 1) ?? "U")
            </div>
            <h3 style="margin: 0; font-size: 1.2rem;">@contact?.FullName</h3>
        </div>

        <!-- Messages Area -->
        <div id="messageArea" style="flex-grow: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 15px;">
            @foreach (var msg in Model)
            {
                bool isMe = msg.SenderId != contact?.Id; // Assuming if sender is not contact, it's me
                
                <div style="display: flex; flex-direction: column; align-items: @(isMe ? "flex-end" : "flex-start");">
                    <div style="max-width: 70%; padding: 10px 15px; border-radius: 15px; background: @(isMe ? "var(--neon-blue)" : "var(--beige-light)"); color: @(isMe ? "var(--charcoal-bg)" : "var(--text-main)"); box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
                        @if (msg.Item != null)
                        {
                            <div style="font-size: 0.8rem; font-weight: bold; margin-bottom: 5px; border-bottom: 1px solid rgba(0,0,0,0.1); padding-bottom: 2px;">
                                Re: @msg.Item.Title
                            </div>
                        }
                        @msg.Content
                    </div>
                    <div style="font-size: 0.7rem; color: #888; margin-top: 5px;">
                        @msg.SentDate.ToString("MMM dd, HH:mm")
                    </div>
                </div>
            }
        </div>

        <!-- Input Area -->
        <div style="padding: 15px; background: rgba(0,0,0,0.2); border-top: 1px solid rgba(255,255,255,0.1);">
            <form asp-action="Send" method="post" style="display: flex; gap: 10px;">
                <input type="hidden" name="receiverId" value="@contact?.Id" />
                <input type="text" name="content" class="form-control" placeholder="Type a message..." required autocomplete="off" style="flex-grow: 1;">
                <button type="submit" class="btn btn-primary" style="padding: 0 20px;">Send</button>
            </form>
        </div>
    </div>
</div>

<script>
    // Scroll to bottom
    var messageArea = document.getElementById('messageArea');
    messageArea.scrollTop = messageArea.scrollHeight;
</script>
