@{
    ViewData["Title"] = "Seller Dashboard";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <h1 style="color: var(--brown-dark); margin-bottom: 10px;">Seller Dashboard</h1>
    <p style="color: var(--text-secondary); margin-bottom: 30px;">Manage your store and track your sales.</p>

    <!-- Stats -->
    <div class="grid grid-4" style="margin-bottom: 40px;">
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 10px;">📦</div>
            <h3 style="color: var(--gold);">@ViewBag.TotalItems</h3>
            <p>Total Items</p>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 10px;">⏳</div>
            <h3 style="color: var(--neon-orange);">@ViewBag.PendingItems</h3>
            <p>Pending Approval</p>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 10px;">✅</div>
            <h3 style="color: var(--neon-green);">@ViewBag.ApprovedItems</h3>
            <p>Active Listings</p>
        </div>
        <div class="card" style="text-align: center;">
            <div style="font-size: 2.5rem; margin-bottom: 10px;">💰</div>
            <h3 style="color: var(--gold);">$@(((decimal)ViewBag.TotalSales).ToString("N2"))</h3>
            <p>Total Sales</p>
        </div>
    </div>

    <!-- Actions -->
    <div style="display: flex; gap: 20px; margin-bottom: 40px;">
        <a href="/Seller/CreateItem" class="btn btn-primary" style="flex: 1; text-align: center; font-size: 1.2rem;">
            ➕ List New Item
        </a>
        <a href="/Seller/MyListings" class="btn btn-secondary" style="flex: 1; text-align: center; font-size: 1.2rem;">
            📋 Manage Listings
        </a>
        <a href="/Seller/Sales" class="btn btn-secondary" style="flex: 1; text-align: center; font-size: 1.2rem;">
            📈 View Sales History
        </a>
    </div>

    <!-- Recent Sales -->
    <div>
        <h3 style="color: var(--brown-dark); margin-bottom: 20px;">Recent Sales</h3>
        @if (ViewBag.RecentSales != null && ((IEnumerable<dynamic>)ViewBag.RecentSales).Any())
        {
            <div class="grid grid-3">
                @foreach (var order in ViewBag.RecentSales)
                {
                    <div class="card card-light">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                            <span style="font-weight: bold;">@order.Item.Title</span>
                            <span style="color: var(--neon-pink);">$@order.TotalAmount.ToString("N2")</span>
                        </div>
                        <div style="font-size: 0.9rem; color: #666; margin-bottom: 5px;">
                            Buyer: @order.Buyer.FullName
                        </div>
                        <div style="font-size: 0.8rem; color: #888;">
                            @order.OrderDate.ToString("MMM dd, yyyy")
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card card-light" style="text-align: center; padding: 30px;">
                <p>No sales yet. Keep listing great items!</p>
            </div>
        }
    </div>
</div>
