@model OldIsGold.Web.Models.EditItemViewModel
@{
    ViewData["Title"] = "Edit Item";
    var categories = ViewBag.Categories as List<OldIsGold.DAL.Models.Category>;
    var existingImages = ViewBag.ExistingImages as List<OldIsGold.DAL.Models.ItemImage>;
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <div class="card" style="max-width: 800px; margin: 0 auto;">
        <h2 style="color: var(--gold); margin-bottom: 30px; text-align: center;">Edit Item</h2>

        <form asp-action="EditItem" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="ItemId" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row" style="display: flex; gap: 20px; flex-wrap: wrap;">
                <div style="flex: 1;">
                    <div style="margin-bottom: 20px;">
                        <label asp-for="Title" class="form-label">Item Title</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label asp-for="CategoryId" class="form-label">Category</label>
                        <select asp-for="CategoryId" class="form-control">
                            @if (categories != null)
                            {
                                foreach (var cat in categories)
                                {
                                    <option value="@cat.CategoryId" selected="@(Model.CategoryId == cat.CategoryId)">@cat.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label asp-for="Price" class="form-label">Price ($)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>

                <div style="flex: 1;">
                    <div style="margin-bottom: 20px;">
                        <label asp-for="Condition" class="form-label">Condition</label>
                        <select asp-for="Condition" class="form-control" asp-items="Html.GetEnumSelectList<OldIsGold.DAL.Models.ItemCondition>()">
                        </select>
                        <span asp-validation-for="Condition" class="text-danger"></span>
                    </div>

                    <div style="margin-bottom: 20px;">
                        <label asp-for="Year" class="form-label">Year</label>
                        <input asp-for="Year" class="form-control" type="number" />
                        <span asp-validation-for="Year" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div style="margin-bottom: 30px;">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <!-- Image Management -->
            <div style="margin-bottom: 30px;">
                <label class="form-label">Current Images</label>
                <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 15px;">
                    @if (existingImages != null)
                    {
                        foreach (var img in existingImages)
                        {
                            <div style="position: relative; width: 100px; height: 100px;">
                                <img src="data:@img.ContentType;base64,@Convert.ToBase64String(img.ImageData)" style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;">
                                <div style="position: absolute; top: -5px; right: -5px;">
                                    <label style="background: red; color: white; border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; cursor: pointer; font-size: 0.8rem;">
                                        <input type="checkbox" name="deleteImageIds" value="@img.ImageId" style="display: none;" onchange="this.parentElement.style.background = this.checked ? 'black' : 'red'">
                                        X
                                    </label>
                                </div>
                            </div>
                        }
                    }
                </div>

                <label class="form-label">Add New Images</label>
                <input type="file" name="newImages" class="form-control" multiple accept="image/*" />
            </div>

            <div style="display: flex; gap: 15px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">Save Changes</button>
                <a href="/Seller/MyListings" class="btn btn-secondary" style="flex: 1;">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
