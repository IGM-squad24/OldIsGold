@model IEnumerable<OldIsGold.DAL.Models.Item>
@{
    ViewData["Title"] = "My Listings";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <h1 style="color: var(--brown-dark); margin: 0;">My Listings</h1>
        <a href="/Seller/CreateItem" class="btn btn-primary">➕ Add New Item</a>
    </div>

    <!-- Filters -->
    <div style="margin-bottom: 20px;">
        <a href="/Seller/MyListings" class="btn @(ViewBag.StatusFilter == null ? "btn-secondary" : "btn-outline-secondary")" style="margin-right: 10px;">All</a>
        <a href="/Seller/MyListings?status=Approved" class="btn @(ViewBag.StatusFilter?.ToString() == "Approved" ? "btn-secondary" : "btn-outline-secondary")" style="margin-right: 10px;">Active</a>
        <a href="/Seller/MyListings?status=Pending" class="btn @(ViewBag.StatusFilter?.ToString() == "Pending" ? "btn-secondary" : "btn-outline-secondary")" style="margin-right: 10px;">Pending</a>
        <a href="/Seller/MyListings?status=Sold" class="btn @(ViewBag.StatusFilter?.ToString() == "Sold" ? "btn-secondary" : "btn-outline-secondary")" style="margin-right: 10px;">Sold</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card" style="text-align: center; padding: 50px;">
            <h3>No items found</h3>
            <p>You haven't listed any items matching this filter.</p>
        </div>
    }
    else
    {
        <div class="grid grid-3">
            @foreach (var item in Model)
            {
                <div class="card card-light" style="position: relative;">
                    <div style="position: absolute; top: 10px; right: 10px; z-index: 10;">
                        <span class="badge @(item.Status == OldIsGold.DAL.Models.ItemStatus.Approved ? "badge-approved" : (item.Status == OldIsGold.DAL.Models.ItemStatus.Pending ? "badge-pending" : "badge-rejected"))">
                            @item.Status
                        </span>
                    </div>
                    
                    <div style="height: 200px; background: #ddd; border-radius: 8px; overflow: hidden; margin-bottom: 15px;">
                        @if (item.Images != null && item.Images.Any())
                        {
                            var mainImage = item.Images.FirstOrDefault(i => i.IsMain) ?? item.Images.First();
                            <img src="data:@mainImage.ContentType;base64,@Convert.ToBase64String(mainImage.ImageData)" style="width: 100%; height: 100%; object-fit: cover;">
                        }
                        else
                        {
                            <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #888;">No Image</div>
                        }
                    </div>

                    <h4 style="margin-bottom: 5px;">@item.Title</h4>
                    <div style="color: var(--neon-pink); font-weight: bold; font-size: 1.2rem; margin-bottom: 15px;">$@item.Price.ToString("N2")</div>

                    <div style="display: flex; gap: 10px;">
                        <a href="/Seller/EditItem/@item.ItemId" class="btn btn-secondary" style="flex: 1; padding: 8px;">Edit</a>
                        <form asp-action="DeleteItem" asp-route-id="@item.ItemId" method="post" style="flex: 1;" onsubmit="return confirm('Are you sure you want to delete this item?');">
                            <button type="submit" class="btn btn-danger" style="width: 100%; padding: 8px;">Delete</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
