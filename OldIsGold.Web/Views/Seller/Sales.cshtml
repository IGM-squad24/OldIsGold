@model IEnumerable<OldIsGold.DAL.Models.Order>
@{
    ViewData["Title"] = "Sales History";
}

<div class="container" style="margin-top: 40px; margin-bottom: 60px;">
    <h1 style="color: var(--brown-dark); margin-bottom: 30px;">Sales History</h1>

    @if (!Model.Any())
    {
        <div class="card" style="text-align: center; padding: 50px;">
            <h3>No sales yet</h3>
            <p>Your sales history will appear here once you start selling.</p>
        </div>
    }
    else
    {
        <div class="card" style="padding: 0; overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: var(--brown-card); color: var(--text-light);">
                    <tr>
                        <th style="padding: 15px; text-align: left;">Order ID</th>
                        <th style="padding: 15px; text-align: left;">Item</th>
                        <th style="padding: 15px; text-align: left;">Buyer</th>
                        <th style="padding: 15px; text-align: left;">Date</th>
                        <th style="padding: 15px; text-align: right;">Amount</th>
                        <th style="padding: 15px; text-align: center;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 15px;">#@order.OrderId</td>
                            <td style="padding: 15px;">
                                <a href="/Item/Details/@order.ItemId" style="color: var(--brown-dark); font-weight: bold;">@order.Item.Title</a>
                            </td>
                            <td style="padding: 15px;">@order.Buyer.FullName</td>
                            <td style="padding: 15px;">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td style="padding: 15px; text-align: right; color: var(--neon-pink); font-weight: bold;">$@order.TotalAmount.ToString("N2")</td>
                            <td style="padding: 15px; text-align: center;">
                                <span class="badge badge-approved">@order.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
